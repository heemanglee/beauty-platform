    {
      "name": "Public Products",
      "item": [
        {
          "name": "List All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/public/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "public", "products"]
            },
            "description": "List all visible products (ON_SALE and SOLD_OUT). No authentication required."
          },
          "response": []
        },
        {
          "name": "List Products by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/public/products?categoryId={{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "public", "products"],
              "query": [
                {
                  "key": "categoryId",
                  "value": "{{categoryId}}"
                }
              ]
            },
            "description": "Filter products by category. Only ON_SALE and SOLD_OUT products are returned."
          },
          "response": []
        },
        {
          "name": "List Products by Seller",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/public/products?sellerId={{sellerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "public", "products"],
              "query": [
                {
                  "key": "sellerId",
                  "value": "{{sellerId}}"
                }
