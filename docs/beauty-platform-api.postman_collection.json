        {
          "name": "Seller Update Product With Images",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{sellerAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{productName}}\",\n  \"price\": {{productPrice}},\n  \"stockQuantity\": {{productStockQuantity}},\n  \"categoryId\": {{categoryId}},\n  \"images\": {\n    \"thumbnailImages\": [\n      {\n        \"s3Key\": \"{{thumbnailS3Key}}\",\n        \"sortOrder\": 1\n      }\n    ],\n    \"mainImages\": [\n      {\n        \"s3Key\": \"{{mainS3Key}}\",\n        \"sortOrder\": 1\n      }\n    ],\n    \"descriptionImages\": [\n      {\n        \"s3Key\": \"{{descriptionS3Key}}\",\n        \"sortOrder\": 1\n      }\n    ]\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/seller/products/{{productId}}",
            "description": "The backend stores the returned s3Key values. Run the Upload Thumbnail/Main/Description Image requests first so the referenced objects exist before calling this request."
          },
          "response": []
        },
