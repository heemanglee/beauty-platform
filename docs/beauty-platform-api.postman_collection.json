            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{productName}}\",\n  \"price\": {{productPrice}},\n  \"stockQuantity\": {{productStockQuantity}},\n  \"categoryId\": {{categoryId}},\n  \"images\": {\n    \"thumbnailImages\": [],\n    \"mainImages\": [],\n    \"descriptionImages\": []\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/seller/products",
            "description": "Create a product in PENDING state. The images array can be empty at creation time."
          },
          "response": []
        },
        {
          "name": "Issue Thumbnail Upload URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('thumbnailS3Key', data.s3Key);",
                  "pm.collectionVariables.set('thumbnailUploadUrl', data.uploadUrl);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{sellerAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"THUMBNAIL\",\n  \"filename\": \"thumbnail.jpg\",\n  \"contentType\": \"image/jpeg\",\n  \"contentLength\": 1024\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/seller/products/{{productId}}/image-upload-url"
          },
          "response": []
        },
        {
          "name": "Upload Thumbnail Image",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "image/jpeg"
              }
            ],
            "body": {
              "mode": "file",
              "file": {
                "src": "{{thumbnailFilePath}}"
              }
            },
            "url": "{{thumbnailUploadUrl}}",
            "description": "Upload the local thumbnail file to the presigned URL returned by the previous request. Set {{thumbnailFilePath}} to a local file path or choose a file in Postman before sending. Re-issue the upload URL if it has expired."
          },
          "response": []
        },
