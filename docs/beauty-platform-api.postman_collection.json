{
  "info": {
    "_postman_id": "3e8bb763-5a8f-4b2e-8cd3-cb0a4d7f0db1",
    "name": "Beauty Platform API",
    "description": "Postman collection for the currently implemented Beauty Platform backend APIs.\n\nRecommended order:\n1. Admin Login\n2. Buyer Signup / Buyer Login\n3. Admin Create Seller\n4. Seller Login\n5. Category setup\n6. Seller product setup\n7. Admin product moderation\n8. Public product browsing\n\nNotes:\n- Update admin credentials if your local seed values differ.\n- The collection stores tokens and generated IDs in collection variables.\n- Product image upload URL issuance depends on the app's product image storage configuration.\n- Public product endpoints do not require authentication.\n- This collection only covers the APIs implemented in the repository today.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "  const runId = String(Date.now());",
          "  pm.collectionVariables.set('runId', runId);",
          "  pm.collectionVariables.set('buyerEmail', `buyer.${runId}@beauty.local`);",
          "  pm.collectionVariables.set('sellerEmail', `seller.${runId}@beauty.local`);",
          "  pm.collectionVariables.set('categoryName', `Skincare ${runId}`);",
          "  pm.collectionVariables.set('updatedCategoryName', `Premium Skincare ${runId}`);",
          "  pm.collectionVariables.set('deletableCategoryName', `Disposable ${runId}`);",
          "  pm.collectionVariables.set('productName', `Glow Serum ${runId}`);",
          "}",
          "if (!pm.collectionVariables.get('productPrice')) {",
          "  pm.collectionVariables.set('productPrice', '32000');",
          "}",
          "if (!pm.collectionVariables.get('productStockQuantity')) {",
          "  pm.collectionVariables.set('productStockQuantity', '10');",
          "}"
        ]
      }
    }
  ],
